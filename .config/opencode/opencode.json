{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "external_directory": "deny",
        "task": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.example": "allow"
        },
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
            "*": "ask",
            "git *": "ask",
            "git push *": "ask",
            "git add *": "allow",
            "git commit *": "allow",
            "git grep *": "allow",
            "git status *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "git blame *": "allow",
            "git -C * push *": "ask",
            "git -C * add *": "allow",
            "git -C * commit *": "allow",
            "git -C * grep *": "allow",
            "git -C * status *": "allow",
            "git -C * diff *": "allow",
            "git -C * log *": "allow",
            "git -C * show *": "allow",
            "git -C * blame *": "allow",
            "rm *": "ask",
            "env *": "allow",
            "printenv *": "allow",
            "stat *": "allow",
            "file *": "allow",
            "du *": "allow",
            "df *": "allow",
            "uname *": "allow",
            "date *": "allow",
            "pwd": "allow",
            "realpath *": "allow",
            "dirname *": "allow",
            "basename *": "allow",
            "diff *": "allow",
            "test *": "allow",
            "[ *": "allow",
            "true": "allow",
            "false": "allow",
            "ls *": "allow",
            "time *": "allow",
            "timeout *": "allow",
            "echo *": "allow",
            "curl *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "grep *": "allow",
            "which *": "allow",
            "wc *": "allow",
            "find *": "allow",
            "sort *": "allow",
            "rg *": "allow",
            "fd *": "allow",
            "jq *": "allow",
            "cat *": "allow",
            "awk *": "allow",
            "cut *": "allow",
            "tr *": "allow",
            "uniq *": "allow",
            "sort *": "allow",
            "rev *": "allow",
            "xargs *": "allow",
            "yes *": "allow",
            "mkdir *": "allow",
            "deno *": "allow",
            "npm *": "allow",
            "npx *": "allow",
            "node *": "allow",
            "ffmpeg *": "allow",
            "docker *": "allow",
            "docker* prune*": "ask",
            "docker* rm *": "ask",
            "docker* rmi *": "ask",
            "docker* kill *": "ask",
            "docker* push *": "ask",
            "docker* down -v*": "ask",
            "docker* down --volumes*": "ask",
            "docker* down --rmi*": "ask",
            "docker* --privileged*": "ask",
            "docker* -v /:/*": "ask",
            "sed *": "allow",
            "sed -i *": "ask",
            "sed --in-place *": "ask",
            "sleep *": "allow",
            "google-chrome *": "allow",
            "touch *": "allow",
            "host *": "allow"
        }
    }
}
