{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "external_directory": "deny",
        "task": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.example": "allow"
        },
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
            "*": "ask",
            "git *": "deny",
            "git commit *": "ask",
            "git push *": "ask",
            "git grep *": "allow",
            "git status *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "git blame *": "allow",
            "git -C * commit *": "ask",
            "git -C * push *": "ask",
            "git -C * grep *": "allow",
            "git -C * status *": "allow",
            "git -C * diff *": "allow",
            "git -C * log *": "allow",
            "git -C * show *": "allow",
            "git -C * blame *": "allow",
            "rm *": "deny",
            "ls *": "allow",
            "time *": "allow",
            "echo *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "grep *": "allow",
            "which *": "allow",
            "wc *": "allow",
            "find *": "allow",
            "rg *": "allow",
            "fd *": "allow",
            "cat *": "allow",
            "mkdir *": "allow",
            "touch *": "allow",
            "npm run build*": "allow"
        }
    }
}
